# Environment Variables for Finance Data Processing Dashboard
# Copy this file to .env and fill in your actual values

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/finance_dashboard

# Atlas (cloud) example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finance_dashboard?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a strong random secret in production (e.g., openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d
